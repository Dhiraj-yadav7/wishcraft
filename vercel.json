{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/signup", "destination": "/login.html" },
    { "source": "/login", "destination": "/login.html" }
  ],
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "src/**/*", "use": "@vercel/static" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ]
}
