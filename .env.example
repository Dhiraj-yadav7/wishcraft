# =========================================================================
# WISHCRAFT ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# =========================================================================

# Application Running Mode & Server Secrets
NODE_ENV=development
JWT_SECRET=your_super_secret_session_key_min_32_chars

# MongoDB Database String
# If left empty/undefined, the app falls back to local JSON db.json storage.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/wishcraft?retryWrites=true&w=majority

# Gemini Artificial Intelligence API Configuration
# Required for generating AI wishes, agendas, video templates, etc.
# If absent, the app falls back to rule-based static templates.
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# Cloudinary Storage Configurations (Optional)
# If provided, avatar photos and generator images are saved permanently to Cloudinary.
# If absent, files fall back to being stored locally as compressed Base64 strings.
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
